# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET_NAME=tc-fase2-alfabetizacao

# BigQuery / Base dos Dados
BQ_PROJECT_ID=seu-projeto-gcp
BASEDOSDADOS_BILLING_PROJECT=seu-projeto-gcp

# Kinesis
KINESIS_STREAM_NAME=alfabetizacao-indicadores-stream

# SNS Alertas
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:alfabetizacao-alerts
ALERT_EMAIL=seu@email.com

# Glue
GLUE_ROLE_ARN=arn:aws:iam::123456789012:role/tc-fase2-glue-role
